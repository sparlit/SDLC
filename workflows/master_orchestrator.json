{
  "name": "Ultimate Master SDLC Orchestrator",
  "nodes": [
    {
      "parameters": {
        "options": {}
      },
      "id": "chat-trigger",
      "name": "Chat Trigger",
      "type": "n8n-nodes-base.chatTrigger",
      "typeVersion": 1,
      "position": [
        -200,
        0
      ]
    },
    {
      "parameters": {
        "interval": 1,
        "unit": "hours"
      },
      "id": "continuous-loop-trigger",
      "name": "Continuous Loop Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        -200,
        200
      ]
    },
    {
      "parameters": {},
      "id": "error-self-healing-trigger",
      "name": "Error Self-Healing Trigger",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        -200,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"You are a lead architect. Create a plan for the project based on chat input. Return JSON array: [{file, action, description}]\"}, {\"role\": \"user\", \"content\": \"{{ $json.chatInput }}\"}]"
            }
          ]
        }
      },
      "id": "orchestrator-planning",
      "name": "Orchestrator Planning",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        50,
        -50
      ]
    },
    {
      "parameters": {
        "command": "grep -rEi \"TODO|FIXME|placeholder|stub|bottleneck|dead end|loose end|loop hole|blind spot|wrapper|build later|fix later|empty wrapper\" /data/project || true"
      },
      "id": "autonomous-gap-scan",
      "name": "Autonomous Gap Scan",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        50,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Fix these SDLC issues: bottlenecks, gaps, stubs, etc. Return a shell command to apply the fix wrapped in ```bash. Issues found: {{ $json.stdout }}\"}, {\"role\": \"user\", \"content\": \"Apply fixes.\"}]"
            }
          ]
        }
      },
      "id": "ai-fix-loop",
      "name": "AI Fix Loop",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        250,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const content = $node[\"AI Fix Loop\"].json.choices[0].message.content;\nconst match = content.match(/```(?:bash|sh)?\\n([\\s\\S]*?)\\n```/);\nconst command = match ? match[1].trim() : content.trim();\nif (['rm -rf /', 'mkfs'].some(d => command.includes(d))) throw new Error('Security violation');\nreturn { command };"
      },
      "id": "fix-sanitizer",
      "name": "Fix Sanitizer",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        200
      ]
    },
    {
      "parameters": {
        "command": "={{ $json.command }} && cd /data/project && (npm test || pytest || true)"
      },
      "id": "apply-and-verify",
      "name": "Apply and Verify",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        650,
        200
      ]
    },
    {
      "parameters": {
        "command": "cd /data/project && git add . && git commit -m \"Autonomous fixing loop: applied fixes\" && git push || echo 'no changes'"
      },
      "id": "commit-verified-fixes",
      "name": "Commit Verified Fixes",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        850,
        200
      ]
    },
    {
      "parameters": {
        "url": "={{ $env.N8N_HOST }}/api/v1/workflows/{{ $json.workflow.id }}",
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-API-KEY",
              "value": "={{ $env.N8N_API_KEY }}"
            }
          ]
        }
      },
      "id": "get-self-json",
      "name": "Get Self JSON",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        50,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Fix this n8n workflow error: {{ $node[\\\"Error Self-Healing Trigger\\\"].json.execution.error.message }}. Return the patched JSON nodes and connections in ```json.\"}, {\"role\": \"user\", \"content\": \"{{ JSON.stringify($json) }}\"}]"
            }
          ]
        }
      },
      "id": "ai-self-patcher",
      "name": "AI Self-Patcher",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        250,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const content = $node[\"AI Self-Patcher\"].json.choices[0].message.content;\nconst match = content.match(/```json\\n([\\s\\S]*?)\\n```/);\nreturn JSON.parse(match ? match[1].trim() : content.trim());"
      },
      "id": "parse-patch",
      "name": "Parse Patch",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        450,
        400
      ]
    },
    {
      "parameters": {
        "method": "PUT",
        "url": "={{ $env.N8N_HOST }}/api/v1/workflows/{{ $node[\\\"Error Self-Healing Trigger\\\"].json.workflow.id }}",
        "headerParameters": {
          "parameters": [
            {
              "name": "X-N8N-API-KEY",
              "value": "={{ $env.N8N_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "nodes",
              "value": "={{ $json.nodes }}"
            },
            {
              "name": "connections",
              "value": "={{ $json.connections }}"
            }
          ]
        }
      },
      "id": "update-self",
      "name": "Update Self",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        650,
        400
      ]
    }
  ],
  "connections": {
    "chat-trigger": {
      "main": [
        [
          {
            "node": "Orchestrator Planning",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "continuous-loop-trigger": {
      "main": [
        [
          {
            "node": "Autonomous Gap Scan",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "error-self-healing-trigger": {
      "main": [
        [
          {
            "node": "Get Self JSON",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Autonomous Gap Scan": {
      "main": [
        [
          {
            "node": "AI Fix Loop",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI Fix Loop": {
      "main": [
        [
          {
            "node": "Fix Sanitizer",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fix Sanitizer": {
      "main": [
        [
          {
            "node": "Apply and Verify",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Apply and Verify": {
      "main": [
        [
          {
            "node": "Commit Verified Fixes",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Self JSON": {
      "main": [
        [
          {
            "node": "AI Self-Patcher",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI Self-Patcher": {
      "main": [
        [
          {
            "node": "Parse Patch",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Patch": {
      "main": [
        [
          {
            "node": "Update Self",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
