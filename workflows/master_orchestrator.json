{
  "name": "Ultimate Master SDLC Orchestrator",
  "nodes": [
    {
      "parameters": {
        "options": {}
      },
      "id": "chat-trigger",
      "name": "Chat Trigger",
      "type": "n8n-nodes-base.chatTrigger",
      "typeVersion": 1,
      "position": [
        -400,
        0
      ]
    },
    {
      "parameters": {
        "interval": 1,
        "unit": "hours"
      },
      "id": "continuous-loop-trigger",
      "name": "Continuous Loop Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        -400,
        200
      ]
    },
    {
      "parameters": {},
      "id": "error-self-healing-trigger",
      "name": "Error Self-Healing Trigger",
      "type": "n8n-nodes-base.errorTrigger",
      "typeVersion": 1,
      "position": [
        -400,
        400
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Break request into tasks. Return JSON array [{file, action, description}]\"}, {\"role\": \"user\", \"content\": \"{{ $json.chatInput }}\"}]"
            }
          ]
        }
      },
      "id": "orchestrator-planning",
      "name": "Orchestrator Planning",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -150,
        0
      ]
    },
    {
      "parameters": {
        "command": "grep -rEi \"TODO|FIXME|placeholder|stub|bottleneck|dead end|loose end|loop hole|blind spot|wrapper|build later|fix later|empty wrapper\" /data/project || true"
      },
      "id": "autonomous-gap-scan",
      "name": "Autonomous Gap Scan",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        -150,
        200
      ]
    },
    {
      "parameters": {
        "batchSize": 5,
        "options": {}
      },
      "id": "parallel-batcher",
      "name": "Parallel Batcher",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 1,
      "position": [
        100,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Fix SDLC issues. Return bash command in ```. Issues: {{ $json.stdout }}\"}]"
            }
          ]
        }
      },
      "id": "ai-fix-loop",
      "name": "AI Fix Loop",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        300,
        200
      ]
    },
    {
      "parameters": {
        "jsCode": "const content = $node[\"AI Fix Loop\"].json.choices[0].message.content;\nconst match = content.match(/```(?:bash|sh)?\\n([\\s\\S]*?)\\n```/);\nconst command = match ? match[1].trim() : content.trim();\nreturn { command };"
      },
      "id": "fix-sanitizer",
      "name": "Fix Sanitizer",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        500,
        200
      ]
    },
    {
      "parameters": {
        "command": "={{ $json.command }} && (npm test || pytest || true)"
      },
      "id": "apply-and-verify",
      "name": "Apply and Verify",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        700,
        200
      ]
    }
  ],
  "connections": {
    "chat-trigger": {
      "main": [
        [
          {
            "node": "Orchestrator Planning",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "continuous-loop-trigger": {
      "main": [
        [
          {
            "node": "Autonomous Gap Scan",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Autonomous Gap Scan": {
      "main": [
        [
          {
            "node": "Parallel Batcher",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parallel Batcher": {
      "main": [
        [
          {
            "node": "AI Fix Loop",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI Fix Loop": {
      "main": [
        [
          {
            "node": "Fix Sanitizer",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fix Sanitizer": {
      "main": [
        [
          {
            "node": "Apply and Verify",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
