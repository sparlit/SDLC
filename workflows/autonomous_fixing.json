{
  "name": "Autonomous Fixing Loop",
  "nodes": [
    {
      "parameters": {
        "interval": 1,
        "unit": "hours"
      },
      "id": "schedule-trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "command": "if [ -f /data/project/.n8n_fix.lock ]; then exit 1; else touch /data/project/.n8n_fix.lock; fi"
      },
      "id": "acquire-lock",
      "name": "Acquire Lock",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        200,
        0
      ]
    },
    {
      "parameters": {
        "command": "grep -rE \"TODO|FIXME|placeholder|stub\" /data/project || true"
      },
      "id": "find-gaps",
      "name": "Find Gaps/Placeholders",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        400,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"You are an autonomous fixing agent. Provide a single shell command to fix the following gaps or placeholders. Wrap the command in ```bash code blocks.\"}, {\"role\": \"user\", \"content\": \"{{ $json.stdout }}\"}]"
            }
          ]
        }
      },
      "id": "ai-fix-generator",
      "name": "AI Fix Generator",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        600,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Review this proposed shell command for security and correctness. Respond ONLY with 'APPROVED' or 'REJECTED: reason'.\"}, {\"role\": \"user\", \"content\": \"{{ $json.choices[0].message.content }}\"}]"
            }
          ]
        }
      },
      "id": "ai-critic",
      "name": "AI Critic",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        800,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.choices[0].message.content }}",
              "operation": "contains",
              "value2": "APPROVED"
            }
          ]
        }
      },
      "id": "is-approved",
      "name": "Is Approved?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1000,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const content = $node[\"AI Fix Generator\"].json.choices[0].message.content;\nconst match = content.match(/```(?:bash|sh|zsh)?\\n([\\s\\S]*?)\\n```/);\nconst command = match ? match[1].trim() : content.trim();\n\nconst dangerous = ['rm -rf /', 'mkfs', 'shutdown', 'poweroff', 'reboot'];\nif (dangerous.some(d => command.includes(d))) {\n  throw new Error('Dangerous command detected');\n}\n\nreturn { command };"
      },
      "id": "sanitize-fix",
      "name": "Sanitize Fix",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1200,
        -50
      ]
    },
    {
      "parameters": {
        "command": "={{ $json.command }}"
      },
      "id": "apply-fix",
      "name": "Apply Fix",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1400,
        -50
      ]
    },
    {
      "parameters": {
        "command": "cd /data/project && npm test || pytest || true"
      },
      "id": "test-after-fix",
      "name": "Test After Fix",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        1600,
        -50
      ]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.exitCode }}",
              "value2": 0
            }
          ]
        }
      },
      "id": "test-pass",
      "name": "Test Pass?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        1800,
        -50
      ]
    },
    {
      "parameters": {
        "command": "cd /data/project && git add . && git commit -m \"Autonomous fix applied and verified\" && git push"
      },
      "id": "git-commit-push",
      "name": "Git Commit & Push",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        2000,
        -100
      ]
    },
    {
      "parameters": {
        "command": "cd /data/project && git checkout . && echo \"Rollback completed due to test failure\""
      },
      "id": "rollback",
      "name": "Rollback",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        2000,
        100
      ]
    },
    {
      "parameters": {
        "command": "rm /data/project/.n8n_fix.lock"
      },
      "id": "release-lock",
      "name": "Release Lock",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        2200,
        0
      ]
    }
  ],
  "connections": {
    "schedule-trigger": {
      "main": [
        [
          {
            "node": "acquire-lock",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "acquire-lock": {
      "main": [
        [
          {
            "node": "find-gaps",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "find-gaps": {
      "main": [
        [
          {
            "node": "ai-fix-generator",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ai-fix-generator": {
      "main": [
        [
          {
            "node": "ai-critic",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ai-critic": {
      "main": [
        [
          {
            "node": "is-approved",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "is-approved": {
      "main": [
        [
          {
            "node": "sanitize-fix",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "sanitize-fix": {
      "main": [
        [
          {
            "node": "apply-fix",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "apply-fix": {
      "main": [
        [
          {
            "node": "test-after-fix",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "test-after-fix": {
      "main": [
        [
          {
            "node": "test-pass",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "test-pass": {
      "main": [
        [
          {
            "node": "git-commit-push",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "rollback",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "git-commit-push": {
      "main": [
        [
          {
            "node": "release-lock",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "rollback": {
      "main": [
        [
          {
            "node": "release-lock",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
