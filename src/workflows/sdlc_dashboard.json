      },
      "id": "55480dd0-a612-419a-9b31-bd7abf1794fb",
      "name": "Omniscient Fix: Save Dashboard (P0)",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        1000,
