{
  "name": "Omniscient Error Orchestrator",
  "nodes": [
    {
      "parameters": {},
      "id": "input-trigger",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.error || $json.result }}",
              "value2": "CONFLICT:",
              "operator": "contains"
            }
          ]
        }
      },
      "id": "check-conflict",
      "name": "Check Conflict",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        150,
        -150
      ]
    },
    {
      "parameters": {
        "workflowId": "task_orchestrator"
      },
      "id": "trigger-planning-fallback",
      "name": "Planning Fallback",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        350,
        -200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "openrouter/free"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"You are the Omniscient Error Classifier. Categorize the error into one of three categories: 'workflow', 'operational', or 'code'.\\n- 'workflow': Structural errors in the n8n workflow logic/JSON.\\n- 'operational': Runtime data issues, missing parameters, or API call failures due to data.\\n- 'code': Errors in the underlying source code, scripts, or infrastructure.\\nReturn ONLY the category name.\"}, {\"role\": \"user\", \"content\": \"Error: {{ $json.error }}\\nContext: {{ JSON.stringify($json) }}\"}]"
            }
          ]
        }
      },
      "id": "error-classifier",
      "name": "Error Classifier",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        200,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const category = $node[\"Error Classifier\"].json.choices[0].message.content.toLowerCase().trim();\nreturn { category };"
      },
      "id": "parse-category",
      "name": "Parse Category",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        0
      ]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "={{ $json.category }}",
                  "type": "string"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "rightValue": "workflow",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "output": 0
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "={{ $json.category }}",
                  "type": "string"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "rightValue": "operational",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "output": 1
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": false,
                  "leftValue": "={{ $json.category }}",
                  "type": "string"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "rightValue": "code",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ]
              },
              "output": 2
            }
          ]
        }
      },
      "id": "route-error",
      "name": "Route Error",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [
        600,
        0
      ]
    },
    {
      "parameters": {
        "workflowId": "agent_workflow_fixer"
      },
      "id": "call-workflow-fixer",
      "name": "Call Workflow Fixer",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        900,
        -150
      ]
    },
    {
      "parameters": {
        "workflowId": "agent_operational_fixer"
      },
      "id": "call-operational-fixer",
      "name": "Call Operational Fixer",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        900,
        0
      ]
    },
    {
      "parameters": {
        "workflowId": "agent_code_fixer"
      },
      "id": "call-code-fixer",
      "name": "Call Code Fixer",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        900,
        150
      ]
    }
  ],
  "connections": {
    "Execute Workflow Trigger": {
      "main": [
        [
          {
            "node": "Check-conflict",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check-conflict": {
      "main": [
        [
          {
            "node": "Planning Fallback",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Error Classifier",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Error Classifier": {
      "main": [
        [
          {
            "node": "Parse Category",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Parse Category": {
      "main": [
        [
          {
            "node": "Route Error",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Route Error": {
      "main": [
        [
          {
            "node": "Call Workflow Fixer",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Call Operational Fixer",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Call Code Fixer",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}