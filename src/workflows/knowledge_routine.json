      "id": "69c83fa5-156b-476f-bd83-c1166ff801e3",
      "name": "Omniscient Fix: AI Summarizer (P0)",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        800,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Update Documentation\"].error !== undefined }",
              "value2": true
            }
          ]
