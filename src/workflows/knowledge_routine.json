      "id": "7bcf5ce7-a5d9-41d5-93ca-2f6c518d5bc3",
      "name": "Omniscient Fix: AI Summarizer (P0)",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        800,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Update Documentation\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "701930ec-febe-435b-a7a9-f854329f0953",
      "name": "Check: Update Documentation (P0)",
      "type": "n8n-nodes-base.if",
