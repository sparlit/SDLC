{
  "name": "IQ200 Unified SDLC Brain",
  "nodes": [
    {
      "parameters": { "options": {} },
      "id": "trigger",
      "name": "Chat Trigger",
      "type": "n8n-nodes-base.chatTrigger",
      "typeVersion": 1,
      "position": [ 0, 0 ]
    },
    {
      "parameters": {
        "command": "python3 /data/project/src/tools/deep_analyzer.py /data/project && python3 /data/project/src/tools/compliance_scanner.py /data/project"
      },
      "id": "scout-analyze",
      "name": "Scout (Deep Analyze + Compliance)",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [ 200, 0 ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "bodyParameters": {
          "parameters": [
            { "name": "model", "value": "google/gemini-2.0-flash-001" },
            { "name": "messages", "value": "=[{\"role\": \"system\", \"content\": \"Propose fixes and AUTOMATICALLY SYNTHESIZE TESTS. Return bash in ```. Issues: {{ $json.stdout }}\"}]" }
          ]
        }
      },
      "id": "devil-critique",
      "name": "Devil (Critique + Test Synthesis)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [ 400, 0 ]
    },
    {
      "parameters": {
        "chatId": "={{ $node[\"Chat Trigger\"].json.chatId }}",
        "text": "Proposed changes detected. Approve deployment?",
        "buttons": [
          { "text": "Approve", "value": "approve" },
          { "text": "Reject", "value": "reject" }
        ]
      },
      "id": "hitl-gatekeeper",
      "name": "HITL Gatekeeper",
      "type": "n8n-nodes-base.chatTrigger",
      "typeVersion": 1,
      "position": [ 600, 0 ]
    },
    {
      "parameters": {
        "jsCode": "const content = $node[\"Devil (Critique + Test Synthesis)\"].json.choices[0].message.content;\nconst match = content.match(/```(?:bash|sh)?\\n([\\s\\S]*?)\\n```/);\nreturn { command: match ? match[1].trim() : content.trim() };"
      },
      "id": "sanitize-engine",
      "name": "Sanitize Engine",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [ 800, 0 ]
    },
    {
      "parameters": {
        "command": "={{ $json.command }} && (npm test || pytest || true)"
      },
      "id": "architect-implement",
      "name": "Architect (Implement + Verify)",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [ 1000, 0 ]
    }
  ],
  "connections": {
    "trigger": { "main": [[{ "node": "scout-analyze", "type": "main", "index": 0 }]] },
    "scout-analyze": { "main": [[{ "node": "devil-critique", "type": "main", "index": 0 }]] },
    "devil-critique": { "main": [[{ "node": "hitl-gatekeeper", "type": "main", "index": 0 }]] },
    "hitl-gatekeeper": { "main": [[{ "node": "sanitize-engine", "type": "main", "index": 0 }]] },
    "sanitize-engine": { "main": [[{ "node": "architect-implement", "type": "main", "index": 0 }]] }
  }
}
