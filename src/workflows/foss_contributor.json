{
  "name": "FOSS Contributor (Bug Bounty)",
  "nodes": [
    {
      "parameters": {
        "interval": 1,
        "unit": "weeks"
      },
      "id": "trigger",
      "name": "Weekly Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "command": "git clone https://github.com/popular/foss-repo /tmp/target && python3 /data/project/src/tools/deep_analyzer.py /tmp/target"
      },
      "id": "scan-external",
      "name": "Scan External Repo",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        200,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"You found bugs in an external FOSS repo: {{ $json.stdout }}. Generate a fix to contribute back.\"}]"
            }
          ]
        }
      },
      "id": "generate-contribution",
      "name": "Generate Contribution",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        400,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Scan External Repo\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "a48312d5-b27c-4904-ab0b-427bb5ed3163",
      "name": "Check: Scan Exter-0-a1aa",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        400,
        -50
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "dee1d10f-3dd0-4cdf-b6ef-0e58689dff8c",
      "name": "Omniscient Fix: Scan Exter-0-a1aa",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        600,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Generate Contribution\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "c8146065-fa91-416d-8f10-706ba0fef728",
      "name": "Check: Generate C-0-fb31",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        600,
        -50
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "76848f36-46a4-40e3-ac69-694bb994f26e",
      "name": "Omniscient Fix: Generate C-0-fb31",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        800,
        0
      ]
    }
  ],
  "connections": {
    "Check: Scan Exter-0-a1aa": {
      "main": [
        [
          {
            "node": "Omniscient Fix: Scan Exter-0-a1aa",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Check: Scan External Repo (P0)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Omniscient Fix: Scan Exter-0-a1aa": {
      "main": [
        [
          {
            "node": "Scan External Repo",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Scan External Repo": {
      "main": [
        [
          {
            "node": "Check: Scan Exter-0-a1aa",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check: Generate C-0-fb31": {
      "main": [
        [
          {
            "node": "Omniscient Fix: Generate C-0-fb31",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Check: Generate Contribution (P0)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Omniscient Fix: Generate C-0-fb31": {
      "main": [
        [
          {
            "node": "Generate Contribution",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate Contribution": {
      "main": [
        [
          {
            "node": "Check: Generate C-0-fb31",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}