    },
    "Check: Trigger Fix Loop (P0)": {
      "main": [
        [
          {
            "node": "Omniscient Fix: Trigger Fix Loop (P0)",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Omniscient Fix: Trigger Fix Loop (P0)": {
      "main": [
        [
          {
            "node": "Trigger Fix Loop",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Trigger Fix Loop": {
