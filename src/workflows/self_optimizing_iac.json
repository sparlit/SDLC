{
  "name": "Self-Optimizing Infrastructure",
  "nodes": [
    {
      "parameters": {
        "interval": 4,
        "unit": "hours"
      },
      "id": "resource-trigger",
      "name": "Resource Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "command": "docker stats --no-stream --format '{{.Container}}: {{.MemUsage}}' | grep n8n"
      },
      "id": "get-resource-usage",
      "name": "Get Resource Usage",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        200,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"You are a DevOps engineer. Analyze this memory usage: {{ $json.stdout }}. If usage is above 80%, generate an OpenTofu (HCL) snippet to increase memory limits for the docker container. Return ONLY the HCL.\"}]"
            }
          ]
        }
      },
      "id": "ai-optimizer",
      "name": "AI Optimizer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        400,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Get Resource Usage\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "8a5b4fad-4df9-4625-ae65-502065e00f40",
      "name": "Check: Get Resour-0-b14a",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        400,
        -50
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "78e99829-73c3-499a-9edf-3607864dba9f",
      "name": "Omniscient Fix: Get Resour-0-b14a",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        600,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"AI Optimizer\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "6b940e40-39c2-4bba-8a46-c1b6be6b723e",
      "name": "Check: AI Optimiz-0-d454",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        600,
        -50
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "e40fa838-be50-4e96-abcc-645d514395d1",
      "name": "Omniscient Fix: AI Optimiz-0-d454",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        800,
        0
      ]
    }
  ],
  "connections": {
    "Check: Get Resour-0-b14a": {
      "main": [
        [
          {
            "node": "Omniscient Fix: Get Resour-0-b14a",
