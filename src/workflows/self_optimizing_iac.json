{
  "name": "Self-Optimizing Infrastructure",
  "nodes": [
    {
      "parameters": {
        "interval": 4,
        "unit": "hours"
      },
      "id": "resource-trigger",
      "name": "Resource Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "command": "docker stats --no-stream --format '{{.Container}}: {{.MemUsage}}' | grep n8n"
      },
      "id": "get-resource-usage",
      "name": "Get Resource Usage",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        200,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"You are a DevOps engineer. Analyze this memory usage: {{ $json.stdout }}. If usage is above 80%, generate an OpenTofu (HCL) snippet to increase memory limits for the docker container. Return ONLY the HCL.\"}]"
            }
          ]
        }
      },
      "id": "ai-optimizer",
      "name": "AI Optimizer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        400,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Get Resource Usage\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "9da36f35-43d7-4062-ab68-d7125bdf0dca",
      "name": "Check: Get Resource Usage (P0)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        400,
        -50
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "fe61ec0e-d7b8-4bd2-9d8e-b2b2a72cee3a",
      "name": "Omniscient Fix: Get Resource Usage (P0)",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        600,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"AI Optimizer\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "39a0ed76-9e83-4a96-82d5-3bb19c871e02",
      "name": "Check: AI Optimizer (P0)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        600,
        -50
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "31151f85-d2b4-4b9f-aa2f-db40d599de1e",
      "name": "Omniscient Fix: AI Optimizer (P0)",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        800,
        0
      ]
    }
  ],
  "connections": {
    "Check: Get Resource Usage (P0)": {
      "main": [
        [
          {
            "node": "Omniscient Fix: Get Resource Usage (P0)",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Check: Get Resource Usage (P0)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Omniscient Fix: Get Resource Usage (P0)": {
      "main": [
        [
          {
            "node": "Get Resource Usage",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Resource Usage": {
      "main": [
        [
          {
            "node": "Check: Get Resource Usage (P0)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check: AI Optimizer (P0)": {
      "main": [
        [
          {
            "node": "Omniscient Fix: AI Optimizer (P0)",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Check: AI Optimizer (P0)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Omniscient Fix: AI Optimizer (P0)": {
      "main": [
        [
          {
            "node": "AI Optimizer",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "AI Optimizer": {
      "main": [
        [
          {
            "node": "Check: AI Optimizer (P0)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}