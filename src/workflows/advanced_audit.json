{
  "name": "Advanced SDLC Security & Complexity Audit",
  "nodes": [
    {
      "parameters": {
        "options": {}
      },
      "id": "trigger",
      "name": "Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "command": "semgrep scan --config auto /data/project"
      },
      "id": "semgrep-scan",
      "name": "Semgrep Scan",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        200,
        -50
      ]
    },
    {
      "parameters": {
        "command": "radon cc -s -a /data/project"
      },
      "id": "radon-complexity",
      "name": "Radon Complexity",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        200,
        150
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Analyze Semgrep and Radon results for security risks and bottlenecks. Results: Semgrep: {{ $node[\\\"semgrep-scan\\\"].json.stdout }}\\nRadon: {{ $node[\\\"radon-complexity\\\"].json.stdout }}\"}]"
            }
          ]
        }
      },
      "id": "ai-audit-report",
      "name": "AI Audit Report",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        450,
        50
      ]
    }
  ],
  "connections": {
    "trigger": {
      "main": [
        [
          {
            "node": "semgrep-scan",
            "type": "main",
            "index": 0
          },
          {
            "node": "radon-complexity",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "semgrep-scan": {
      "main": [
        [
          {
            "node": "ai-audit-report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "radon-complexity": {
      "main": [
        [
          {
            "node": "ai-audit-report",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
