        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"Analyze these high-risk files and suggest proactive refactoring to prevent future bugs. Files: {{ $json.stdout }}\"}]"
            }
          ]
        }
      },
      "id": "proactive-fixer",
      "name": "Proactive Fixer",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        400,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Risk Analysis\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "421dd261-287f-40f0-89d9-3e0481d951fa",
      "name": "Check: Risk Analysis (P0)",
