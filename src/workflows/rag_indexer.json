{
  "name": "RAG Context Indexer",
  "nodes": [
    {
      "parameters": {
        "interval": 4,
        "unit": "hours"
      },
      "id": "trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "command": "find /data/project -type f -not -path '*/.*' | xargs -I {} cat {}"
      },
      "id": "read-files",
      "name": "Read Project Files",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        200,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://chroma:8000/api/v1/collections/sdlc/upsert",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "documents",
              "value": "={{ $json.stdout }}"
            },
            {
              "name": "ids",
              "value": "={{ $json.fileName }}"
            }
          ]
        }
      },
      "id": "chroma-upsert",
      "name": "Chroma Upsert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        400,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Read Project Files\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "595af9cf-ef8b-43d5-988c-d45784ded1d4",
      "name": "Check: Read Proje-0-3d96",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        400,
        -50
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "18610458-a477-4feb-82a7-d410d4f2387b",
      "name": "Omniscient Fix: Read Proje-0-3d96",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        600,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Chroma Upsert\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "0428d6d8-afe1-433d-8932-6e3b61314abe",
      "name": "Check: Chroma Ups-0-d1a8",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        600,
        -50
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "94b6455b-8327-4df5-b720-2cbeb5f9259b",
      "name": "Omniscient Fix: Chroma Ups-0-d1a8",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        800,
        0
      ]
    }
  ],
  "connections": {
    "Check: Read Proje-0-3d96": {
      "main": [
        [
          {
            "node": "Omniscient Fix: Read Proje-0-3d96",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Check: Read Project Files (P0)",
