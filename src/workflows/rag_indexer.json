{
  "name": "RAG Context Indexer",
  "nodes": [
    {
      "parameters": {
        "interval": 4,
        "unit": "hours"
      },
      "id": "trigger",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "command": "find /data/project -type f -not -path '*/.*' | xargs -I {} cat {}"
      },
      "id": "read-files",
      "name": "Read Project Files",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        200,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://chroma:8000/api/v1/collections/sdlc/upsert",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "documents",
              "value": "={{ $json.stdout }}"
            },
            {
              "name": "ids",
              "value": "={{ $json.fileName }}"
            }
          ]
        }
      },
      "id": "chroma-upsert",
      "name": "Chroma Upsert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        400,
        0
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Read Project Files\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "bf14f94c-0ed2-4744-9caa-3e05c918da5c",
      "name": "Check: Read Project Files (P0)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        400,
        -100
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "4b45ca81-7e49-4a8b-b986-fe05a85c0e7e",
      "name": "Omniscient Fix: Read Project Files (P0)",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        600,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={ $node[\"Chroma Upsert\"].error !== undefined }",
              "value2": true
            }
          ]
        }
      },
      "id": "48ef2406-399d-4333-859a-71df65730229",
      "name": "Check: Chroma Upsert (P0)",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        600,
        -100
      ]
    },
    {
      "parameters": {
        "workflowId": "omniscient_error_orchestrator",
        "options": {
          "waitForResults": true
        }
      },
      "id": "ee783d2d-79d4-4f63-96f7-49ea3400f994",
      "name": "Omniscient Fix: Chroma Upsert (P0)",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        800,
        0
      ]
    }
  ],
  "connections": {
    "Check: Read Project Files (P0)": {
      "main": [
        [
          {
            "node": "Omniscient Fix: Read Project Files (P0)",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Omniscient Fix: Read Project Files (P0)": {
      "main": [
        [
          {
            "node": "Read Project Files",
