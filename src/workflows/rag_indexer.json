            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check: Chroma Ups-0-d1a8": {
      "main": [
        [
          {
            "node": "Omniscient Fix: Chroma Ups-0-d1a8",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Check: Chroma Upsert (P0)",
