{
  "name": "Full Evolution Engine",
  "nodes": [
    {
      "parameters": {
        "interval": 1,
        "unit": "weeks"
      },
      "id": "weekly-trigger",
      "name": "Weekly Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "command": "cat /data/project/SDLC_PERF.log /data/project/SDLC_KNOWLEDGE.md"
      },
      "id": "read-all-context",
      "name": "Read All Context",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        200,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $env.OPENROUTER_API_KEY }}"
            }
          ]
        },
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "google/gemini-2.0-flash-001"
            },
            {
              "name": "messages",
              "value": "=[{\"role\": \"system\", \"content\": \"You are a lead architect. Based on the project performance and history: {{ $json.stdout }}, suggest improvements to the ARCHITECTURE.md file. Return ONLY the markdown content.\"}]"
            }
          ]
        }
      },
      "id": "ai-evolve-arch",
      "name": "AI Evolve Arch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        450,
        0
      ]
    },
    {
      "parameters": {
        "command": "echo '{{ $json.choices[0].message.content }}' > /data/project/ARCHITECTURE.md"
      },
      "id": "update-arch",
      "name": "Update Arch",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [
        700,
        0
      ]
    }
  ],
  "connections": {
    "weekly-trigger": {
      "main": [
        [
          {
            "node": "read-all-context",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "read-all-context": {
      "main": [
        [
          {
            "node": "ai-evolve-arch",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "ai-evolve-arch": {
      "main": [
        [
          {
            "node": "update-arch",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
